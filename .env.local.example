# Copy this file to `.env.local` and fill in your real values.
# Never commit `.env.local` — it's already in .gitignore.

# Supabase — from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Resend — from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Sender email. For early testing, use Resend's shared test address:
RESEND_FROM_EMAIL=onboarding@resend.dev
# Later, when you add and verify your own domain in Resend, use:
# RESEND_FROM_EMAIL=reminders@yourdomain.com

# Your app's public URL (used to build payment links in emails).
# Locally: http://localhost:3000
# In production: your Vercel domain
NEXT_PUBLIC_APP_URL=http://localhost:3000
